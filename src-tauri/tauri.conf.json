{
  "productName": "Archive Metz",
  "version": "0.2.0",
  "identifier": "fr.archive-metz",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Archive Metz",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "visible": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**",
          "**/*",
          "/**",
          "C:/**",
          "D:/**",
          "E:/**",
          "F:/**",
          "G:/**",
          "//*/**",
          "//*/*/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5MjhDQjA2NzAwRjdCNTQKUldSVWV3OXdCc3NvV1hVdXQyRVhzSW1KRkY1NnZrNWUwTUhWSmFPOTVoNnFWL2s2RkJBaHNra2sK",
      "endpoints": [
        "https://github.com/Della-Rocca/Archive3D-Metz/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
